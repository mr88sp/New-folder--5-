---
import MainLayout from '../../layouts/MainLayout.astro';
import Breadcrumb from '../../components/layout/Breadcrumb';
import Container from '../../components/ui/Container';
import ProductImageGallery from '../../components/products/ProductImageGallery';
import ProductInfo from '../../components/products/ProductInfo';
import RelatedProducts from '../../components/products/RelatedProducts';
import { getSiteContent, getProducts } from '../../utils/api';

// دریافت محصولات از API
const allProducts = await getProducts();

// دریافت محتوای سایت از API
const siteContent = await getSiteContent();

// دریافت ID محصول از پارامتر URL
const { id } = Astro.params;

// پیدا کردن محصول مورد نظر
const product = allProducts.find((p: any) => p.id == id);

// اگر محصول پیدا نشد، به صفحه 404 هدایت شود
if (!product) {
  return Astro.redirect('/404');
}

const pageTitle = `${product.name} | ${siteContent.brand_name || 'سهیلی وود'}`;
const pageDescription = product.fullDescription || product.description;
const pageKeywords = `${product.name}, ${product.brand || 'MDF'}, MDF, ورق کابینت`;

const ogImage = product.image_url || undefined;
---

<MainLayout title={pageTitle} description={pageDescription} keywords={pageKeywords} ogImage={ogImage}>
  <div class="pb-16">
    <Breadcrumb client:only="react" />
    
    <Container className="pt-8" client:only="react">
      {/* ===== بخش اصلی محصول ===== */}
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12">
        {/* گالری تصاویر */}
        <ProductImageGallery
          images={product.image_url ? [product.image_url] : []}
          productName={product.name}
          client:only="react"
        />

        {/* اطلاعات محصول */}
        <ProductInfo product={product} client:only="react" />
      </div>

      {/* ===== محصولات مرتبط ===== */}
      <RelatedProducts
        products={allProducts}
        currentProductId={product.id}
        client:only="react"
      />
    </Container>
  </div>
</MainLayout>
